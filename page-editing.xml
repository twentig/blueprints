		<content:encoded><![CDATA[<!-- wp:cover {"url":"https://images.unsplash.com/photo-1648747067101-55dfb609864b?q=80\u0026amp;w=2400\u0026amp;h=1000\u0026amp;auto=format\u0026amp;fit=crop\u0026amp;ixlib=rb-4.1.0\u0026amp;ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D\u0026amp;fp-y=.67\u0026blend= 33000000\u0026blend-mode=normal","dimRatio":50,"isUserOverlayColor":true,"minHeight":75,"minHeightUnit":"vh","sizeSlug":"large","metadata":{"name":"Hero cover"},"align":"full","style":{"spacing":{"padding":{"bottom":"var:preset|spacing|70"}}},"layout":{"type":"constrained"}} -->
