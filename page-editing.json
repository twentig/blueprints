{
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "preferredVersions": {
    "php": "latest",
    "wp": "beta"
  },
  "login": true,
  "landingPage": "/wp-admin/edit.php?post_type=page",
  "features": {
    "networking": true
  },
  "steps": [
    {
      "step": "setSiteOptions",
      "options": {
        "blogname": "Playground"
      }
    },
    {
      "step": "installTheme",
      "themeData": {
        "resource": "url",
        "url": "https://github.com/twentig/twentig-one/releases/latest/download/twentig-one.zip"
      },
      "options": {
        "activate": true
      }
    },
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "wordpress.org/plugins",
        "slug": "twentig"
      },
      "options": {
        "activate": true
      }
    },
    {
      "step": "runPHP",
      "code": "<?php require_once '/wordpress/wp-load.php'; delete_transient('_twentig_activation_redirect'); $items = get_posts(array('numberposts' => -1, 'post_type' => array('post','page'), 'post_status' => 'any')); foreach ($items as $item) { wp_delete_post($item->ID, true); }"
    },
    {
      "step": "importWxr",
      "file": {
        "resource": "url",
        "url": "https://raw.githubusercontent.com/twentig/blueprints/main/page-editing.xml"
      }
    },
    {
      "step": "runPHP",
      "code": "<?php require_once '/wordpress/wp-load.php'; $page = get_page_by_path('free'); if ($page) { update_option('show_on_front', 'page'); update_option('page_on_front', $page->ID); }"
    }
  ]
}
